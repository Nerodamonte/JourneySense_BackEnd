@startuml Share Journey & Earn Reward Point
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam linetype ortho


actor Traveler
participant "<<UI>>\n:JourneyDetailPage" as JourneyUI
participant "<<controller>>\n:JourneyController" as JourneyController
participant "<<service>>\n:JourneyShareService" as ShareService
participant "<<repository>>\n:JourneyRepository" as JourneyRepo
participant "<<service>>\n:RewardService" as RewardService
database "JSEADatabase" as DB

Traveler -> JourneyUI : 1. userShareJourney(journeyId, shareChannel)
activate JourneyUI
activate Traveler
JourneyUI -> JourneyController : 2. POST /journeys/{id}/share(shareRequest)
activate JourneyController
JourneyController -> ShareService : 3. shareJourney(journeyId, travelerId, shareChannel)
activate ShareService

ShareService -> JourneyRepo : 4. getById(journeyId)
activate JourneyRepo
JourneyRepo -> DB : 5. SELECT Journey, JourneyWaypoints
activate DB
DB --> JourneyRepo : 5.1 result
deactivate DB
JourneyRepo --> ShareService : 4.1 journey
deactivate JourneyRepo

alt journey not found
    ShareService --> JourneyController : 3.1 notFound()

    JourneyController --> JourneyUI : 2.1 showError()

    JourneyUI --> Traveler : 1.1 displayError()

else journey found
    ShareService -> RewardService : 5. addRewardPoints(travelerId, points, "share_journey")
    activate RewardService
    RewardService -> DB : 6. UPDATE UserProfile SET reward_points
    activate DB
    DB --> RewardService : 6.1 updateResult
    deactivate DB
    RewardService --> ShareService : 5.1 pointsAdded
    deactivate RewardService

    ShareService --> JourneyController : 3.2 shareResult(shareLink, pointsEarned)
    deactivate ShareService
    JourneyController --> JourneyUI : 2.2 shareResponse(shareLink)
    deactivate JourneyController
    JourneyUI --> Traveler : 1.2 displayShareSuccess(shareLink)
    deactivate JourneyUI
    deactivate Traveler
end
@enduml
