@startuml Journey Setup - Sequence Diagram
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor Traveler
participant "JourneySetupPage\n<<UI>>" as JourneyUI
participant "JourneyController\n<<controller>>" as JourneyController
participant "JourneyService\n<<service>>" as JourneyService
participant "GoongMapsService\n<<service>>" as GoongMapsService
participant "JourneyRepository\n<<repository>>" as JourneyRepository
database "JSEADatabase" as DB

== Open journey setup form ==
Traveler -> JourneyUI : 1. openJourneySetup()
activate JourneyUI
activate Traveler
JourneyUI --> Traveler : 1.1 showJourneyForm()
deactivate JourneyUI
deactivate Traveler

== Submit form & process ==
Traveler -> JourneyUI : 2. submitJourneyForm(journeyForm)
activate JourneyUI
activate Traveler
JourneyUI -> JourneyController : 3. POST /journeys/setup(journeyForm)
activate JourneyController
JourneyController -> JourneyService : 4. validateAndCreateJourney(journeyForm)
activate JourneyService

alt invalid data
    JourneyService --> JourneyController : 4.1 validationError(errors)
    JourneyController --> JourneyUI : 3.1 showValidationErrors(errors)
    JourneyUI --> Traveler : 2.1 displayValidationErrors()
else valid data
    JourneyService -> GoongMapsService : 5. analyzeRouteContext(origin, destination, vehicleType, timeBudget, detourDistance)
    activate GoongMapsService
    GoongMapsService --> JourneyService : 5.1 routeContext
    deactivate GoongMapsService

    JourneyService -> JourneyRepository : 6. saveAsync(journey, waypoints)
    activate JourneyRepository
    JourneyRepository -> DB : 7. INSERT Journey, JourneyWaypoints
    activate DB
    DB --> JourneyRepository : 7.1 insertResult
    deactivate DB
    JourneyRepository --> JourneyService : 6.1 journey
    deactivate JourneyRepository

    JourneyService --> JourneyController : 4.2 journeyCreated(journey)
    deactivate JourneyService
    JourneyController --> JourneyUI : 3.2 showJourneySummary(journey)
    deactivate JourneyController
    JourneyUI --> Traveler : 2.2 displayJourneyConfirmation()
    deactivate JourneyUI
    deactivate Traveler
end
@enduml
