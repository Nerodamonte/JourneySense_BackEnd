@startuml 12c - Update Micro-Experience
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam linetype ortho

actor "Operation Staff" as OpStaff
participant "MicroExpManagementPage\n<<UI>>" as MicroUI
participant "MicroExperienceController\n<<controller>>" as MicroController
participant "MicroExperienceService\n<<service>>" as MicroService
participant "MicroExperienceRepository\n<<repository>>" as MicroRepo
database "JSEADatabase" as DB

OpStaff -> MicroUI : 1. updateMicroExperience(id, formData)
activate MicroUI
MicroUI -> MicroController : 2. PUT /micro-experiences/{id}(updateRequest)
activate MicroController
MicroController -> MicroService : 3. updateMicroExperience(id, updateRequest)
activate MicroService

MicroService -> MicroRepo : 4. getById(id)
activate MicroRepo
MicroRepo -> DB : 5. SELECT FROM micro_experiences
DB --> MicroRepo : 5.1 result
MicroRepo --> MicroService : 4.1 microExperience
deactivate DB

alt [4.1 not found]
    MicroService --> MicroController : 3.1 notFound()
    deactivate MicroService
    MicroController --> MicroUI : 2.1 showError()
    deactivate MicroController
    MicroUI --> OpStaff : 1.1 displayError()
    deactivate MicroUI
else [4.1 found]
    MicroService -> MicroRepo : 6. update(microExperience)
    MicroRepo -> DB : 7. UPDATE micro_experiences
    DB --> MicroRepo : 7.1 updateResult
    MicroRepo --> MicroService : 6.1 updated
    deactivate DB
    deactivate MicroRepo

    MicroService --> MicroController : 3.2 updated(microExperience)
    deactivate MicroService
    MicroController --> MicroUI : 2.2 updateResponse()
    deactivate MicroController
    MicroUI --> OpStaff : 1.2 showUpdated()
    deactivate MicroUI
end
@enduml
