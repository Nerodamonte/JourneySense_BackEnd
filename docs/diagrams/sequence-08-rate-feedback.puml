@startuml Rate & Feedback - Mark as Visited, Upload Photos, Write Feedback, Earn Reward Point
!theme plain
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam linetype ortho

actor Traveler
participant "<<UI>>\n:ExperienceDetailPage" as ExpUI
participant "<controller>>\n:ExperienceController" as ExpController
participant "<<service>>\n:RateFeedbackService" as ExpService
participant "<<repository>>\n:VisitRepository" as VisitRepo
participant "<<repository>>\n:RatingRepository" as RatingRepo
participant "<<repository>>\n:FeedbackRepository" as FeedbackRepo
participant "<<service>>\n:RewardService" as RewardService
database "JSEADatabase" as DB

Traveler -> ExpUI : 1. userSubmitVisitWithFeedback(experienceId, journeyId, rating, feedbackText, photoUrls)
activate ExpUI
activate Traveler
ExpUI -> ExpController : 2. POST /experiences/visit(visitRequest)
activate ExpController
ExpController -> ExpService : 3. createVisitWithFeedback(request, travelerId)
activate ExpService

ExpService -> VisitRepo : 4. existsVisitAsync(travelerId, experienceId, journeyId)
activate VisitRepo
VisitRepo -> DB : 5. SELECT FROM Visit
activate DB
DB --> VisitRepo : 5.1 result
deactivate DB
VisitRepo --> ExpService : 4.1 exists
deactivate VisitRepo

alt already visited
    ExpService --> ExpController : 3.1 conflict(409 "Already visited")

    ExpController --> ExpUI : 2.1 showConflict()
  
    ExpUI --> Traveler : 1.1 displayError()

else not visited
    ExpService -> VisitRepo : 6. saveAsync(visit)
    activate VisitRepo
    VisitRepo -> DB : 7. INSERT Visit
    activate DB
    DB --> VisitRepo : 7.1 insertResult
    deactivate DB
    VisitRepo --> ExpService : 6.1 visit
    deactivate VisitRepo

    ExpService -> RewardService : 8. addRewardPoints(travelerId, points, "mark_visited")
    activate RewardService
    RewardService -> DB : 9. UPDATE UserProfile SET reward_points
    activate DB
    DB --> RewardService : 9.1 updateResult
    deactivate DB
    RewardService --> ExpService : 8.1 pointsAdded
    deactivate RewardService

    opt has rating
        ExpService -> RatingRepo : 10. saveAsync(rating)
        activate RatingRepo
        RatingRepo -> DB : 11. INSERT Rating
        activate DB
        DB --> RatingRepo : 11.1 insertResult
        deactivate DB
        RatingRepo --> ExpService : 10.1 rating
        deactivate RatingRepo
    end

    opt has feedback or photos
        ExpService -> FeedbackRepo : 12. saveAsync(feedback)
        activate FeedbackRepo
        FeedbackRepo -> DB : 13. INSERT Feedback
        activate DB
        DB --> FeedbackRepo : 13.1 insertResult
        deactivate DB
        FeedbackRepo --> ExpService : 12.1 feedback
        deactivate FeedbackRepo
    end

    ExpService --> ExpController : 3.2 visitCreated(visit)
    deactivate ExpService
    ExpController --> ExpUI : 2.2 visitResponse(visit)
    deactivate ExpController
    ExpUI --> Traveler : 1.2 displayThankYou()
    deactivate ExpUI
    deactivate Traveler
end
@enduml
